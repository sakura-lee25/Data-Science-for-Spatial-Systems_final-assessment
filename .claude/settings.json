{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75"
  },
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pytest *)",
      "Bash(jupyter *)",
      "Bash(git *)",
      "Bash(source *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push * main)",
      "Bash(pip install --break-system-packages *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'DONE=$(grep -c \"\\[x\\]\" .claude/memory/progress.md 2>/dev/null || echo 0); TOTAL=$(grep -c \"\\[\" .claude/memory/progress.md 2>/dev/null || echo 0); BRANCH=$(git branch --show-current 2>/dev/null || echo detached); VENV=$([[ -n \"$VIRTUAL_ENV\" ]] && echo \"✅\" || echo \"⚠️ 未激活\"); echo \"📅 $(date \"+%Y-%m-%d %A\") | 🌿 $BRANCH | 📊 进度 $DONE/$TOTAL | 🐍 venv: $VENV | 💡 /recap 恢复上下文\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"{\\\"feedback\\\": \\\"💾 工作结束前记得 /wrap-up 保存记忆\\\"}\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(*.py)|Edit(*.py)",
        "hooks": [
          {
            "type": "command",
            "command": "python -m black $CLAUDE_FILE_PATHS 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
